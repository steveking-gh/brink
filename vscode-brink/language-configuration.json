{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "/*", "close": " */", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "wordPattern": "(-[1-9][0-9_]*i?|[a-zA-Z_][a-zA-Z0-9_]*|[0-9][0-9_]*[uiUI]?)",
  "indentationRules": {
    "increaseIndentPattern": "\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "onEnterRules": [
    {
      "beforeText": "/\\*\\*(?!/)([^\\*]|\\*(?!/))*$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s* \\*[^/]*$",
      "action": { "indent": "none", "appendText": "* " }
    }
  ]
}
