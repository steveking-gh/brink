// region_nested_2.brink: FLASH1 is fully inside FLASH (containment).  This is
// allowed so that nested sections can bind to sub-regions.  No EXEC_70.
// inner section nest1 anchors to FLASH1.addr; effective constraint is FLASH & FLASH1 = FLASH1.
region FLASH {
    addr = 0x08000000;
    size = 4;
}
region FLASH1 {
    addr = 0x08000000;
    size = 1;
}

section top in FLASH {
    wr nest1;
}
section nest1 in FLASH1 {
    wr8 0x01;
}

output top;
