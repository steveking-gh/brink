// Backward rebase via set_abs is valid: abs_base can move to any address.
// Useful for images with multiple load regions at different physical RAM addresses.
section foo {
    wrs "Hello";
    set_abs 0x900;   // backward rebase is now valid — no error
    assert sizeof(foo) == 5;
    assert abs() == 0x900;
    assert off() == 0;
}

output foo 0x1000;
