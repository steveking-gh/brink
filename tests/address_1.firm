section fiz {
    assert addr() == 6;
    assert addr_offset() == 6;
    assert sec_offset() == 0;
    wrs "fiz";
    assert addr() == 9;
    assert addr_offset() == 9;
    assert sec_offset() == 3;
}


section bar {
    assert addr() == 3;
    assert addr_offset() == 3;
    assert sec_offset() == 0;
    wrs "bar";
    assert addr() == 6;
    assert addr_offset() == 6;
    assert sec_offset() == 3;
    wr fiz;
    assert addr() == 9;
    assert addr_offset() == 9;
    assert sec_offset() == 6;
}

// top level section
section foo {
    assert addr() == 0;
    assert addr_offset() == 0;
    assert sec_offset() == 0;
    wrs "foo";
    assert addr() == 3;
    assert addr_offset() == 3;
    assert sec_offset() == 3;
    wr bar;
    assert addr() == 9;
    assert addr_offset() == 9;
    assert sec_offset() == 9;
    wr boo;
    assert addr() == 12;
    assert addr_offset() == 12;
    assert sec_offset() == 12;
}

// section after reference
section boo {
    assert addr() == 9;
    assert addr_offset() == 9;
    assert sec_offset() == 0;
    wrs "boo";
    assert addr() == 12;
    assert addr_offset() == 12;
    assert sec_offset() == 3;
}

output foo;