section fiz {
    assert addr() == 0x1006;
    assert addr_offset() == 0x6;
    assert sec_offset() == 0x0;
    wrs "fiz";
    assert addr() == 0x1009;
    assert addr_offset() == 0x9;
    assert sec_offset() == 0x3;
}


section bar {
    assert addr() == 0x1003;
    assert addr_offset() == 0x3;
    assert sec_offset() == 0x0;
    wrs "bar";
    assert addr() == 0x1006;
    assert addr_offset() == 0x6;
    assert sec_offset() == 0x3;
    wr fiz;
    assert addr() == 0x1009;
    assert addr_offset() == 0x9;
    assert sec_offset() == 0x6;
}

// top level section
section foo {
    set_addr 0x1000;
    assert addr() == 0x1000;
    assert addr_offset() == 0x0;
    assert sec_offset() == 0x0;
    wrs "foo";
    assert addr() == 0x1003;
    assert addr_offset() == 0x3;
    assert sec_offset() == 0x3;
    wr bar;
    assert addr() == 0x1009;
    assert addr_offset() == 0x9;
    assert sec_offset() == 0x9;
    wr boo;
    assert addr() == 0x100C;
    assert addr_offset() == 0xC;
    assert sec_offset() == 0xC;
}

// section after reference
section boo {
    assert addr() == 0x1009;
    assert addr_offset() == 0x9;
    assert sec_offset() == 0x0;

    assert addr(fiz) == 0x1006;
    assert addr_offset(fiz) == 0x6;

    wrs "boo";
    assert addr() == 0x100C;
    assert addr_offset() == 0xC;
    assert sec_offset() == 0x3;
}

output foo;