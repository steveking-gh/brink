// region_exec78_bad_start.brink: B starts before A's start address.
// The intersection A & B = [0x1080, 0x1100) is non-empty, so ERR_190 does not
// fire.  But B.addr (0x1000) is before the intersection start (0x1080), meaning
// the section 'inner' would need to anchor at 0x1000 which is outside A.
// ERR_191 must fire.
region A {
    addr = 0x1080;
    size = 0x100;
}
region B {
    addr = 0x1000;
    size = 0x200;
}
section outer in A {
    wr inner;
}
section inner in B {
    wr8 0;
}
output outer;
