// region_exec73_partial_overlap.brink: inner section (in B) is called from outer
// (in A).  Effective region is the intersection A & B ([0x1080, 0x1100),
// size = 128 bytes).  Writing 192 bytes exceeds the intersection -> ERR_186.
region A {
    addr = 0x1000;
    size = 0x100;
}
region B {
    addr = 0x1080;
    size = 0x100;
}
section outer in A {
    wr inner;
}
section inner in B {
    wr8 0, 192;
}
output outer;
