// An empty child that calls set_addr writes zero bytes.
// Parent addr and addr_offset must be completely unchanged after the wr.
// This probes the child_size=0 path through section exit.

section empty_relocatable {
    set_addr 0xDEAD_0000u;
    // no writes
}

section parent {
    set_addr 0x1000;
    wr8 0x11, 3;
    assert addr() == 0x1003;
    assert addr_offset() == 3;
    wr empty_relocatable;
    // child wrote 0 bytes; addr_base must be restored; addr_offset unchanged
    assert addr() == 0x1003;
    assert addr_offset() == 3;
    assert sec_offset() == 3;
    wr8 0x22, 2;
    assert addr() == 0x1005;
    assert sizeof(parent) == 5;
}

output parent;
