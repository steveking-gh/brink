// Corner case: nested top-level if/else blocks.
// The prune loop must promote the inner If node from the outer taken branch,
// then evaluate the inner condition on the next iteration.
// A=1, B=1 -> both taken -> section combo defined.
// Expected output: 0xCC
const A = 1;
const B = 1;

if A {
    if B {
        section combo {
            wr8 0xCC;
        }
    }
}

section main {
    wr combo;
}

output main;
