// Nest regions exactly fill the regions size
region FLASH {
    addr = 0x08000000;
    size = 4;
}
section top in FLASH {
    wr nest1;
}
section nest1 {
    wr8 0x01;
    wr nest2;
}
section nest2 {
    wr8 0x02;
    wr nest3;
}
section nest3 {
    wr8 0x03;
    wr nest4;
}
section nest4 {
    wr8 0x04;
}


assert (sizeof(top) == 4);
assert (addr(nest1) == 0x8000000);
assert (addr(nest2) == 0x8000001);
assert (addr(nest3) == 0x8000002);
assert (addr(nest4) == 0x8000003);
output top;
