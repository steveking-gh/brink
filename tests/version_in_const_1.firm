// Version builtins are compile-time constants and may be used in const expressions.
const MAJOR = __FIRMION_VERSION_MAJOR;
const MINOR = __FIRMION_VERSION_MINOR;
const PATCH = __FIRMION_VERSION_PATCH;

section image {
    assert MAJOR >= 0u;
    assert MINOR >= 7u;
    assert PATCH >= 0u;
    wr8 0;
}

output image;
