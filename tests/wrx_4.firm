
// Test expressions in wrx
section foo {
    wr8  (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 0 + 0 + 36 = 39
    wr16 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 1 + 0 + 36 = 40
    wr24 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 3 + 0 + 36 = 42
    wr32 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 6 + 0 + 36 = 45
    wr40 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 10 + 0 + 36 = 49
    wr48 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 15 + 0 + 36 = 54
    wr56 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 21 + 0 + 36 = 60
    wr64 (1 + 2) + addr_offset() + addr(foo) + sizeof(foo); // 3 + 28 + 0 + 36 = 67
    assert sizeof(foo) == 36;
}

output foo;
