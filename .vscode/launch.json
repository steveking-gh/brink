    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'firmion' named_arg_crc",
            "cargo": {
                "args": [
                    "build",
                    "--bin=firmion",
                    "--package=firmion"
                ],
                "filter": {
                    "name": "firmion",
                    "kind": "bin"
                }
            },
            "args": ["-v",
                     "-v",
                     "-v",
                     "-v",
                     "${workspaceFolder}/tests/named_arg_crc.firm"],
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'firmion'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=firmion",
                    "--package=firmion"
                ],
                "filter": {
                    "name": "firmion",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug integration test 'integration'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--test=integration",
                    "--package=firmion"
                ],
                "filter": {
                    "name": "integration",
                    "kind": "test"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}