// Computes CRC32C over exactly the data bytes, excluding the CRC field.
// Separating payload into its own section lets the section-name form hash
// only those bytes (no digest placeholder included).
//
// CRC32C([0xAA, 0xBB, 0xCC, 0xDD]) = 0xF7CEEA9E, LE: [0x9E, 0xEA, 0xCE, 0xF7]
// Total output: 8 bytes.
section payload {
    wr8 0xAA; wr8 0xBB; wr8 0xCC; wr8 0xDD;
}
section data {
    wr payload;
    wr std::crc32c(payload);
    assert sizeof(data) == 8;
}

output data;
