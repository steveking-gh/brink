// Computes MD5 over 16 bytes [0x00..0x0F], excluding the digest field.
// Input size (16 bytes) equals the MD5 digest size.
// Separating payload into its own section lets the section-name form hash
// only those bytes (no digest placeholder included).
//
// MD5([0x00, 0x01, ..., 0x0F]):
//   [0x1A, 0xC1, 0xEF, 0x01, 0xE9, 0x6C, 0xAF, 0x1B,
//    0xE0, 0xD3, 0x29, 0x33, 0x1A, 0x4F, 0xC2, 0xA8]
// Total output: 32 bytes.
section payload {
    wr8 0x00; wr8 0x01; wr8 0x02; wr8 0x03;
    wr8 0x04; wr8 0x05; wr8 0x06; wr8 0x07;
    wr8 0x08; wr8 0x09; wr8 0x0A; wr8 0x0B;
    wr8 0x0C; wr8 0x0D; wr8 0x0E; wr8 0x0F;
}
section data {
    wr payload;
    wr std::md5(payload);
    assert sizeof(data) == 32;
}

output data;
