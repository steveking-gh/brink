// Computes SHA-256 over a single byte [0xAB], excluding the digest field.
// Separating payload into its own section lets the section-name form hash
// only that byte (no digest placeholder included).
//
// SHA-256([0xAB]):
//   [0x08, 0x7D, 0x80, 0xF7, 0xF1, 0x82, 0xDD, 0x44,
//    0xF1, 0x84, 0xAA, 0x86, 0xCA, 0x34, 0x48, 0x88,
//    0x53, 0xEB, 0xCC, 0x04, 0xF0, 0xC6, 0x0D, 0x52,
//    0x94, 0x91, 0x9A, 0x46, 0x6B, 0x46, 0x38, 0x31]
// Total output: 33 bytes.
section payload {
    wr8 0xAB;
}
section data {
    wr payload;
    wr std::sha256(payload);
    assert sizeof(data) == 33;
}

output data;
