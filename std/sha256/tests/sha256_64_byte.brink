// Computes SHA-256 over 64 bytes [0x00..0x3F] using the explicit range form.
// 64 bytes spans two SHA-256 compression blocks, exercising multi-block hashing.
//
// SHA-256([0x00, 0x01, ..., 0x3F]):
//   [0xFD, 0xEA, 0xB9, 0xAC, 0xF3, 0x71, 0x03, 0x62,
//    0xBD, 0x26, 0x58, 0xCD, 0xC9, 0xA2, 0x9E, 0x8F,
//    0x9C, 0x75, 0x7F, 0xCF, 0x98, 0x11, 0x60, 0x3A,
//    0x8C, 0x44, 0x7C, 0xD1, 0xD9, 0x15, 0x11, 0x08]
// Total output: 96 bytes.
section data {
    wr8 0x00; wr8 0x01; wr8 0x02; wr8 0x03;
    wr8 0x04; wr8 0x05; wr8 0x06; wr8 0x07;
    wr8 0x08; wr8 0x09; wr8 0x0A; wr8 0x0B;
    wr8 0x0C; wr8 0x0D; wr8 0x0E; wr8 0x0F;
    wr8 0x10; wr8 0x11; wr8 0x12; wr8 0x13;
    wr8 0x14; wr8 0x15; wr8 0x16; wr8 0x17;
    wr8 0x18; wr8 0x19; wr8 0x1A; wr8 0x1B;
    wr8 0x1C; wr8 0x1D; wr8 0x1E; wr8 0x1F;
    wr8 0x20; wr8 0x21; wr8 0x22; wr8 0x23;
    wr8 0x24; wr8 0x25; wr8 0x26; wr8 0x27;
    wr8 0x28; wr8 0x29; wr8 0x2A; wr8 0x2B;
    wr8 0x2C; wr8 0x2D; wr8 0x2E; wr8 0x2F;
    wr8 0x30; wr8 0x31; wr8 0x32; wr8 0x33;
    wr8 0x34; wr8 0x35; wr8 0x36; wr8 0x37;
    wr8 0x38; wr8 0x39; wr8 0x3A; wr8 0x3B;
    wr8 0x3C; wr8 0x3D; wr8 0x3E; wr8 0x3F;
    wr std::sha256(0, 64);
    assert sizeof(data) == 96;
}

output data;
