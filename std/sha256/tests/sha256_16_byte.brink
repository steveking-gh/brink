// Computes SHA-256 over 16 bytes [0x00..0x0F] using the explicit range form.
//
// SHA-256([0x00, 0x01, ..., 0x0F]):
//   [0xBE, 0x45, 0xCB, 0x26, 0x05, 0xBF, 0x36, 0xBE,
//    0xBD, 0xE6, 0x84, 0x84, 0x1A, 0x28, 0xF0, 0xFD,
//    0x43, 0xC6, 0x98, 0x50, 0xA3, 0xDC, 0xE5, 0xFE,
//    0xDB, 0xA6, 0x99, 0x28, 0xEE, 0x3A, 0x89, 0x91]
// Total output: 48 bytes.
section data {
    wr8 0x00; wr8 0x01; wr8 0x02; wr8 0x03;
    wr8 0x04; wr8 0x05; wr8 0x06; wr8 0x07;
    wr8 0x08; wr8 0x09; wr8 0x0A; wr8 0x0B;
    wr8 0x0C; wr8 0x0D; wr8 0x0E; wr8 0x0F;
    wr std::sha256(0, 16);
    assert sizeof(data) == 48;
}

output data;
