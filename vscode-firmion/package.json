{
  "name": "vscode-firmion",
  "displayName": "Firmion",
  "description": "Syntax highlighting for the Firmion binary image DSL (.firm files)",
  "version": "0.1.0",
  "publisher": "steveking-gh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/steveking-gh/firmion"
  },
  "homepage": "https://github.com/steveking-gh/firmion",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "firmion",
        "aliases": ["Firmion", "firmion"],
        "extensions": [".firm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "firmion",
        "scopeName": "source.firm",
        "path": "./syntaxes/firmion.tmLanguage.json"
      }
    ]
  }
}
