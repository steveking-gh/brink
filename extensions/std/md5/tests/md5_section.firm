// Computes MD5 using the section-name form.
//
// The section-name form slices the entire section from the output image,
// including the 16 zeroed placeholder bytes pre-allocated for the digest
// field itself.  Input to the hash is therefore 20 bytes:
//   [0x01, 0x02, 0x03, 0x04, 0x00 * 16]
//
// MD5 of those 20 bytes:
//   [0xBD, 0x5A, 0x23, 0x7A, 0xFE, 0xB1, 0x85, 0x55,
//    0xFE, 0x26, 0x2E, 0x5D, 0x03, 0x7B, 0xB6, 0x6F]
// Total output: 20 bytes.
//
// To hash only the data bytes (excluding the digest field), place them in a
// separate section and pass that section to the extension.
section data {
    wr8 0x01; wr8 0x02; wr8 0x03; wr8 0x04;
    wr std::md5(data);
    assert sizeof(data) == 20;
}

assert sizeof(std::md5) == 16;

output data;
